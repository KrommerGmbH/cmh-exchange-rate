{
  "name": "@krommergmbh/cmh-exchange-rate",
  "version": "1.0.0",
  "description": "EUR-based exchange rate client — ECB daily XML with Yahoo Finance fallback",
  "author": "KrommerGmbH",
  "license": "MIT",
  "keywords": ["exchange-rate", "ecb", "yahoo-finance", "shopware", "currency"],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "tsup": {
    "entry": ["src/index.ts"],
    "format": ["esm", "cjs"],
    "dts": true,
    "sourcemap": true,
    "clean": true
  }
}